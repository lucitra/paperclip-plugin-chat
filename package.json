{
  "name": "@lucitra/paperclip-plugin-chat",
  "version": "0.6.1",
  "description": "Multi-adapter AI chat plugin for Paperclip — supports Claude, Codex, and OpenCode",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "build": "tsc && node ./scripts/build-ui.mjs",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ./vitest.config.ts"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "2026.331.0-canary.4",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "esbuild": "^0.27.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vitest": "3.2.4"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/webprismdevin/paperclip-plugin-chat.git"
  }
}
